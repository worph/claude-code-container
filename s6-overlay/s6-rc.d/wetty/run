#!/command/with-contenv sh
# Wait for sshd to be ready and password to be set
sleep 2

# Read the generated SSH password
SSH_PASS=$(cat /run/claude-ssh-pass 2>/dev/null)

exec wetty --host 0.0.0.0 --port "${WETTY_PORT:-3000}" \
    --ssh-host 127.0.0.1 \
    --ssh-port 22 \
    --ssh-user claude \
    --ssh-pass "${SSH_PASS}" \
    --ssh-auth password \
    --command "/home/claude/scripts/claude-session.sh" \
    --base /
