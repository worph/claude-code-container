# Anthropic API Key for Claude Code
# Option 1: Use API key - set your key here
# Option 2: Use Claude Pro/Max subscription - leave empty and authenticate via OAuth on first run
ANTHROPIC_API_KEY=

# Password for terminal access (required for security)
AUTH_PASSWORD=your-secure-password-here

# Enable/disable MCP server for programmatic access (default: true)
MCP_ENABLED=true